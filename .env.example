# Core runtime settings
TZ=UTC

# OpenPLC Runtime
# OpenPLC Runtime is included automatically by the stack.
OPENPLC_RUNTIME_IMAGE=ghcr.io/autonomy-logic/openplc-runtime:latest
OPENPLC_RUNTIME_PORT=8443

# Node-RED
NODE_RED_PORT=1880

# PostgreSQL
POSTGRES_DB=pallas
POSTGRES_USER=pallas
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432

# PGAdmin
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=change-me
PGADMIN_PORT=5050

# FastAPI
FASTAPI_PORT=8000
