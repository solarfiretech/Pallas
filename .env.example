# Copy this file to .env before startup. Full contract, defaults, and ranges:
# documentation/environment-variables.md

# Core runtime settings (optional; non-empty IANA time-zone name)
TZ=UTC

# OpenPLC Runtime
# OpenPLC Runtime is included automatically by the stack.
OPENPLC_RUNTIME_IMAGE=ghcr.io/autonomy-logic/openplc-runtime@sha256:76bc9e4647f1e9177779156e3668426711e5f12769e9fe140b48c6b35fb4a840
OPENPLC_RUNTIME_PORT=8443

# Node-RED
NODE_RED_IMAGE=nodered/node-red:4.1.11-debian@sha256:4d46f0a52a65ab45d37c1a785f635286d49d17fe0dbc547ff724beefb8d42ac1
NODE_RED_PORT=1880

# PostgreSQL
POSTGRES_IMAGE=postgres:16.10-alpine@sha256:029660641a0cfc575b14f336ba448fb8a75fd595d42e1fa316b9fb4378742297
POSTGRES_DB=pallas
POSTGRES_USER=pallas
# Required. Placeholder only; credential hardening is tracked separately.
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432

# PGAdmin
PGADMIN_IMAGE=dpage/pgadmin4:9.6.0@sha256:2c7d73e13bd6c30b1d53e4c25d0d6d81adbd0799c4f4d6a09efc5d68fca5d16d
# Required.
PGADMIN_DEFAULT_EMAIL=admin@example.com
# Required. Placeholder only; credential hardening is tracked separately.
PGADMIN_DEFAULT_PASSWORD=change-me
PGADMIN_PORT=5050

# FastAPI
FASTAPI_PORT=8000

# OPC UA polling (all optional)
OPCUA_ENDPOINT_URL=opc.tcp://openplc-runtime:4840/openplc/opcua
OPCUA_NAMESPACE_URI=urn:openplc:opcua:cocktails
OPCUA_BROWSE_ROOT=ns=0;i=85
OPCUA_MAX_DEPTH=8
OPCUA_TIMEOUT_SECONDS=10

# Aggregate service health (all optional)
HEALTHCHECK_TIMEOUT_SECONDS=3
OPENPLC_HEALTHCHECK_URL=https://openplc-runtime:8443/
OPENPLC_EXPECTED_HTTP_STATUSES=200,404
NODE_RED_HEALTHCHECK_URL=http://node-red:1880/
NODE_RED_EXPECTED_HTTP_STATUSES=200
PGADMIN_HEALTHCHECK_URL=http://pgadmin:80/
PGADMIN_EXPECTED_HTTP_STATUSES=200,302
POSTGRES_HEALTHCHECK_HOST=postgres
POSTGRES_HEALTHCHECK_PORT=5432
